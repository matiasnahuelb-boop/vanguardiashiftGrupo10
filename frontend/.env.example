# VanguardiaShift — Frontend Environment Variables
# Copiar este archivo como .env y ajustar los valores

# URL del backend API
# Desarrollo local:
VITE_API_URL=http://localhost:8000/api

# Producción (Railway):
# VITE_API_URL=https://vanguardiashift-backend.railway.app/api

# Nombre de la aplicación (aparece en el título del navegador)
VITE_APP_NAME=VanguardiaShift
