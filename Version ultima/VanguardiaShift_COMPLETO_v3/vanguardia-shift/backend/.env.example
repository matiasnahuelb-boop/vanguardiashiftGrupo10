APP_NAME=VanguardiaShift
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos (MySQL en producción)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vanguardiashift
DB_USERNAME=root
DB_PASSWORD=

# Para tests automáticos: SQLite en memoria (ver phpunit.xml)
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# CORS: URL del frontend (desarrollo)
FRONTEND_URL=http://localhost:5173

# Sanctum: dominios de confianza
SANCTUM_STATEFUL_DOMAINS=localhost:5173
